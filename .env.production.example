# Cinema Club DC — Production Environment Variables
# Copy to .env.production at the repo root and fill in real values.
#   cp .env.production.example .env.production

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-hex-string

# SQLite database path (relative to backend working directory inside the container)
DATABASE_URL=sqlite:///cinemaclub.db

# Public-facing URL (CORS, email links, invite URLs)
FRONTEND_URL=https://your-domain.example

# Gmail SMTP (optional — falls back to console logging if unset)
SMTP_EMAIL=
SMTP_PASSWORD=

# Movie metadata enrichment
TMDB_API_TOKEN=
TMDB_API_KEY=
OMDB_API_KEY=

# Discord bot / internal API
INTERNAL_API_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
SITE_URL=https://your-domain.example
DEFAULT_GROUP_ID=1

# AMC (optional — enable AMC scrapers once approved)
AMC_API_KEY=
